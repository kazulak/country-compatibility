# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs.
# https://editorconfig.org/

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Python files (PEP 8 standard: 4 spaces indentation)
[*.py]
indent_style = space
indent_size = 4

# Web assets (HTML, CSS, JavaScript: 2 spaces indentation)
[*.{html,css,js}]
indent_style = space
indent_size = 2

# Markdown documentation
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
